// =============================================================================
// AgendaAí — Schema Avançado (SaaS Completo)
// Provider: SQLite (dev) | Troque para postgresql em produção
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 1. USER — Prestador de serviço
// =============================================================================
model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  emailVerified  DateTime? @map("email_verified")
  image          String?

  // Perfil público
  slug           String   @unique
  bio            String?
  phone          String?

  // Fuso horário — ex: "America/Sao_Paulo", "America/New_York"
  timezone       String   @default("America/Sao_Paulo")

  // Configurações de agendamento
  bookingPageTitle    String?  @map("booking_page_title")   // "Agende uma consulta"
  bookingPageBanner   String?  @map("booking_page_banner")  // URL da imagem de capa
  minimumNotice       Int      @default(60)   @map("minimum_notice")    // minutos de antecedência mínima
  maxDaysInAdvance    Int      @default(60)   @map("max_days_in_advance") // quantos dias à frente o cliente pode agendar

  // Stripe
  stripeCustomerId    String?  @unique @map("stripe_customer_id")
  stripeAccountId     String?  @unique @map("stripe_account_id")   // Stripe Connect (para receber pagamentos)
  stripeAccountStatus String?  @map("stripe_account_status")       // "active" | "pending" | "restricted"

  // Plano SaaS
  plan           String   @default("free")   // "free" | "pro" | "business"
  planExpiresAt  DateTime? @map("plan_expires_at")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  // Relações
  accounts       Account[]
  sessions       Session[]
  services       Service[]
  availability   Availability[]
  bookings       Booking[]
  customers      Customer[]

  @@map("users")
}

// =============================================================================
// 2. ACCOUNT — Tokens OAuth (Google Calendar, etc.)
//    Segue a spec do NextAuth/Auth.js para compatibilidade total
// =============================================================================
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String                       // "oauth" | "oidc" | "email"
  provider          String                       // "google" | "github" etc.
  providerAccountId String  @map("provider_account_id")

  // Tokens OAuth 2.0
  refresh_token     String?
  access_token      String?
  expires_at        Int?                         // Unix timestamp
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  // Google Calendar específico
  googleCalendarId          String? @map("google_calendar_id")          // ID do calendário primário
  googleCalendarEnabled     Boolean @default(false) @map("google_calendar_enabled")
  googleCalendarSyncToken   String? @map("google_calendar_sync_token")  // Para sync incremental
  googleCalendarLastSyncAt  DateTime? @map("google_calendar_last_sync_at")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// =============================================================================
// 3. SESSION & VERIFICATION TOKEN — NextAuth/Auth.js
// =============================================================================
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// 4. SERVICE — Serviços oferecidos pelo prestador
// =============================================================================
model Service {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")

  name                 String                        // "Consulta Inicial", "Sessão de Fisioterapia"
  description          String?
  slug                 String                        // URL: /agendar/joao/consulta-inicial
  color                String   @default("#22c55e")  // Cor no calendário (hex)
  isActive             Boolean  @default(true)  @map("is_active")
  isPublic             Boolean  @default(true)  @map("is_public")   // Visível na página pública?

  // Tempo
  durationInMinutes    Int      @map("duration_in_minutes")          // ex: 60
  bufferTimeBefore     Int      @default(0)  @map("buffer_time_before")  // minutos antes do slot
  bufferTimeAfter      Int      @default(0)  @map("buffer_time_after")   // minutos depois do slot

  // Preço
  price                Int      @default(0)   // em centavos (0 = gratuito)
  currency             String   @default("BRL")
  paymentRequired      Boolean  @default(false) @map("payment_required")  // Exige pagamento para confirmar?

  // Videoconferência
  isVideoCall          Boolean  @default(false) @map("is_video_call")
  videoCallProvider    String?  @map("video_call_provider")   // "google_meet" | "zoom" | "custom"
  customMeetingUrl     String?  @map("custom_meeting_url")    // URL fixa (ex: Zoom pessoal)

  // Limites
  maxAdvanceBookingDays Int?    @map("max_advance_booking_days")  // Sobrescreve o do User
  minimumNoticeMinutes  Int?    @map("minimum_notice_minutes")    // Sobrescreve o do User

  // Capacidade (para grupos / webinars)
  maxParticipants      Int      @default(1) @map("max_participants")

  position             Int      @default(0)   // Ordenação na página pública

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt      @map("updated_at")

  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings             Booking[]
  availability         Availability[]  // Um serviço pode ter disponibilidade própria

  @@unique([userId, slug])
  @@map("services")
}

// =============================================================================
// 5. AVAILABILITY — Blocos de disponibilidade semanal
//    Suporta múltiplos blocos por dia (ex: 09-12 e 14-18)
//    Pode ser global (serviceId = null) ou por serviço específico
// =============================================================================
model Availability {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  serviceId   String?  @map("service_id")   // null = regra global para todos os serviços

  // Dia da semana: 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
  dayOfWeek   Int      @map("day_of_week")

  // Horários em formato "HH:MM" — armazenados no timezone do User
  startTime   String   @map("start_time")   // ex: "09:00"
  endTime     String   @map("end_time")     // ex: "12:00"

  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Permite múltiplos blocos: (userId, serviceId, dayOfWeek) NÃO tem unique constraint
  @@index([userId, serviceId, dayOfWeek])
  @@map("availability")
}

// =============================================================================
// 6. CUSTOMER — Mini-CRM
//    Um Customer pertence a um User (prestador) e pode ter múltiplos Bookings
// =============================================================================
model Customer {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")         // Prestador dono deste cliente

  name      String
  email     String
  phone     String?
  notes     String?                           // Anotações privadas do prestador
  tags      String?                           // JSON array: ["vip", "retorno"] — SQLite não tem array nativo
  source    String?                           // "organic" | "referral" | "instagram" etc.

  // Estatísticas desnormalizadas (atualizadas via aplicação)
  totalBookings     Int      @default(0)  @map("total_bookings")
  totalSpentCents   Int      @default(0)  @map("total_spent_cents")
  lastBookingAt     DateTime? @map("last_booking_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  // Um prestador não pode ter dois registros do mesmo e-mail de cliente
  @@unique([userId, email])
  @@index([userId, lastBookingAt])
  @@map("customers")
}

// =============================================================================
// 7. BOOKING — Agendamento confirmado
// =============================================================================
model Booking {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")       // Prestador
  serviceId   String   @map("service_id")
  customerId  String   @map("customer_id")

  // Datas e horários armazenados em UTC
  startAt     DateTime @map("start_at")      // UTC
  endAt       DateTime @map("end_at")        // UTC

  // Fuso horário do cliente no momento do agendamento (para exibição correta)
  customerTimezone  String  @default("America/Sao_Paulo") @map("customer_timezone")

  // Status do agendamento
  // pending_payment | confirmed | cancelled_by_provider | cancelled_by_customer | completed | no_show
  status      String   @default("confirmed") @map("status")
  cancelledAt DateTime? @map("cancelled_at")
  cancelReason String?  @map("cancel_reason")

  // Pagamento
  // unpaid | paid | refunded | partially_refunded
  paymentStatus         String  @default("unpaid") @map("payment_status")
  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")
  stripeChargeId        String? @unique @map("stripe_charge_id")
  paidAmountCents       Int     @default(0)  @map("paid_amount_cents")
  paidAt                DateTime? @map("paid_at")
  refundedAmountCents   Int     @default(0)  @map("refunded_amount_cents")
  refundedAt            DateTime? @map("refunded_at")

  // Videoconferência
  meetingUrl            String? @map("meeting_url")          // Link gerado (Google Meet, Zoom)
  googleCalendarEventId String? @map("google_calendar_event_id")  // ID do evento no GCal do prestador

  // Informações extras capturadas no momento do agendamento
  customerNotes         String? @map("customer_notes")       // O que o cliente escreveu no campo "observações"
  internalNotes         String? @map("internal_notes")       // Anotações privadas do prestador

  // Token único para o cliente gerenciar (cancelar sem login)
  manageToken           String  @unique @default(cuid()) @map("manage_token")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  service           Service           @relation(fields: [serviceId], references: [id])
  customer          Customer          @relation(fields: [customerId], references: [id])
  notificationLogs  NotificationLog[]

  @@index([userId, startAt])
  @@index([userId, status])
  @@index([customerId])
  @@index([stripePaymentIntentId])
  @@map("bookings")
}

// =============================================================================
// 8. NOTIFICATION LOG — Rastreamento de notificações enviadas
// =============================================================================
model NotificationLog {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")

  // Canal: EMAIL | WHATSAPP | SMS
  type      String

  // Tipo de mensagem: booking_confirmed | booking_reminder_24h | booking_reminder_1h
  //                   booking_cancelled | booking_rescheduled | payment_received
  template  String

  // Destinatário
  recipient String   // email ou número de telefone

  // Estado: PENDING | SENT | FAILED
  status    String   @default("PENDING")

  // Metadados do provedor externo
  providerMessageId String? @map("provider_message_id")  // ID retornado pelo Resend, Twilio, etc.
  errorMessage      String? @map("error_message")          // Detalhes do erro em caso de FAILED

  // Conteúdo (útil para auditoria e reenvio)
  subject   String?  // Assunto do e-mail
  body      String?  // Corpo da mensagem (texto)

  scheduledFor  DateTime? @map("scheduled_for")  // Para lembretes agendados
  sentAt        DateTime? @map("sent_at")

  createdAt DateTime @default(now()) @map("created_at")

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status, scheduledFor])  // Para a fila de envio de lembretes pendentes
  @@map("notification_logs")
}
