// ============================================================================
// AgendAI SaaS — Schema Prisma 7 (PostgreSQL / Supabase)
// ============================================================================
// IMPORTANTE:
//   - O provider do generator é "prisma-client" (Prisma 7, não "prisma-client-js")
//   - O output é OBRIGATÓRIO em Prisma 7 (não gera mais em node_modules)
//   - A URL do banco vai no prisma.config.ts, NÃO aqui no datasource
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS — Valores controlados para evitar strings mágicas
// ============================================================================

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("booking_status")
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED

  @@map("payment_status")
}

enum NotificationType {
  EMAIL
  WHATSAPP
  SMS

  @@map("notification_type")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED

  @@map("notification_status")
}

enum UserPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE

  @@map("user_plan")
}

// ============================================================================
// USER — Prestador de serviço (owner do SaaS)
// ============================================================================

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       DateTime? @map("email_verified")
  image               String?
  password            String?
  slug                String    @unique
  bio                 String?
  phone               String?
  timezone            String    @default("America/Sao_Paulo")
  bookingPageTitle    String?   @map("booking_page_title")
  bookingPageBanner   String?   @map("booking_page_banner")
  minimumNotice       Int       @default(60) @map("minimum_notice") // minutos de antecedência mínima
  maxDaysInAdvance    Int       @default(60) @map("max_days_in_advance")
  stripeCustomerId    String?   @unique @map("stripe_customer_id")
  stripeAccountId     String?   @unique @map("stripe_account_id")
  stripeAccountStatus String?   @map("stripe_account_status")
  plan                UserPlan  @default(FREE)
  planExpiresAt       DateTime? @map("plan_expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  accounts     Account[]
  sessions     Session[]
  services     Service[]
  availability Availability[]
  bookings     Booking[]
  customers    Customer[]

  @@map("users")
}

// ============================================================================
// ACCOUNT — NextAuth + tokens do Google Calendar
// ============================================================================

model Account {
  id                       String    @id @default(cuid())
  userId                   String    @map("user_id")
  type                     String
  provider                 String
  providerAccountId        String    @map("provider_account_id")
  refresh_token            String?   @db.Text
  access_token             String?   @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?   @db.Text
  id_token                 String?   @db.Text
  session_state            String?
  googleCalendarId         String?   @map("google_calendar_id")
  googleCalendarEnabled    Boolean   @default(false) @map("google_calendar_enabled")
  googleCalendarSyncToken  String?   @map("google_calendar_sync_token")
  googleCalendarLastSyncAt DateTime? @map("google_calendar_last_sync_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ============================================================================
// SESSION — NextAuth session management
// ============================================================================

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================================
// VERIFICATION TOKEN — NextAuth email verification
// ============================================================================

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// SERVICE — Serviços oferecidos pelo prestador
// ============================================================================

model Service {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  name                  String
  description           String?  @db.Text
  slug                  String
  color                 String   @default("#6366f1") // Indigo-500 (premium look)
  isActive              Boolean  @default(true) @map("is_active")
  isPublic              Boolean  @default(true) @map("is_public")
  durationInMinutes     Int      @map("duration_in_minutes")
  bufferTimeBefore      Int      @default(0) @map("buffer_time_before") // minutos de buffer antes
  bufferTimeAfter       Int      @default(0) @map("buffer_time_after") // minutos de buffer depois
  price                 Int      @default(0) // em centavos (ex: 5000 = R$ 50,00)
  currency              String   @default("BRL")
  paymentRequired       Boolean  @default(false) @map("payment_required")
  isVideoCall           Boolean  @default(false) @map("is_video_call")
  videoCallProvider     String?  @map("video_call_provider") // "google_meet" | "zoom" | "custom"
  customMeetingUrl      String?  @map("custom_meeting_url")
  maxAdvanceBookingDays Int?     @map("max_advance_booking_days")
  minimumNoticeMinutes  Int?     @map("minimum_notice_minutes")
  maxParticipants       Int      @default(1) @map("max_participants")
  position              Int      @default(0) // ordenação na página pública
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  availability Availability[]

  @@unique([userId, slug])
  @@map("services")
}

// ============================================================================
// AVAILABILITY — Múltiplos blocos de horário por dia
// ============================================================================

model Availability {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  serviceId String?  @map("service_id") // null = disponibilidade global do prestador
  dayOfWeek Int      @map("day_of_week") // 0 = Domingo, 6 = Sábado
  startTime String   @map("start_time") // "09:00" (HH:mm)
  endTime   String   @map("end_time") // "12:00" (HH:mm)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([userId, serviceId, dayOfWeek])
  @@map("availability")
}

// ============================================================================
// CUSTOMER — Mini-CRM do prestador
// ============================================================================

model Customer {
  id              String    @id @default(cuid())
  userId          String    @map("user_id") // prestador "dono" deste cliente
  name            String
  email           String
  phone           String?
  notes           String?   @db.Text
  tags            String[]  @default([])
  source          String? // "booking_page" | "manual" | "import"
  totalBookings   Int       @default(0) @map("total_bookings")
  totalSpentCents Int       @default(0) @map("total_spent_cents")
  lastBookingAt   DateTime? @map("last_booking_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([userId, email])
  @@index([userId, lastBookingAt])
  @@map("customers")
}

// ============================================================================
// BOOKING — Agendamento propriamente dito
// ============================================================================

model Booking {
  id                    String        @id @default(cuid())
  userId                String        @map("user_id") // prestador
  serviceId             String        @map("service_id")
  customerId            String        @map("customer_id")
  startAt               DateTime      @map("start_at")
  endAt                 DateTime      @map("end_at")
  customerTimezone      String        @default("America/Sao_Paulo") @map("customer_timezone")
  status                BookingStatus @default(CONFIRMED)
  cancelledAt           DateTime?     @map("cancelled_at")
  cancelReason          String?       @map("cancel_reason")
  paymentStatus         PaymentStatus @default(UNPAID)
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?       @unique @map("stripe_charge_id")
  paidAmountCents       Int           @default(0) @map("paid_amount_cents")
  paidAt                DateTime?     @map("paid_at")
  refundedAmountCents   Int           @default(0) @map("refunded_amount_cents")
  refundedAt            DateTime?     @map("refunded_at")
  meetingUrl            String?       @map("meeting_url")
  googleCalendarEventId String?       @map("google_calendar_event_id")
  customerNotes         String?       @map("customer_notes") @db.Text
  internalNotes         String?       @map("internal_notes") @db.Text
  manageToken           String        @unique @default(cuid()) @map("manage_token")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  notificationLogs NotificationLog[]

  @@index([userId, startAt])
  @@index([userId, status])
  @@index([customerId])
  @@map("bookings")
}

// ============================================================================
// NOTIFICATION LOG — Rastreamento de envios (email, WhatsApp, SMS)
// ============================================================================

model NotificationLog {
  id                String             @id @default(cuid())
  bookingId         String             @map("booking_id")
  type              NotificationType
  template          String // "booking_confirmation" | "reminder_24h" | "cancellation" etc.
  recipient         String // email ou telefone do destinatário
  status            NotificationStatus @default(PENDING)
  providerMessageId String?            @map("provider_message_id") // ID do provider (SendGrid, Twilio etc.)
  errorMessage      String?            @map("error_message") @db.Text
  subject           String? // assunto do email (quando aplicável)
  body              String?            @db.Text // corpo da mensagem
  scheduledFor      DateTime?          @map("scheduled_for") // para notificações agendadas (ex: lembrete)
  sentAt            DateTime?          @map("sent_at")
  createdAt         DateTime           @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status, scheduledFor])
  @@map("notification_logs")
}