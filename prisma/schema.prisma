generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       DateTime? @map("email_verified")
  image               String?
  password            String?
  slug                String    @unique
  bio                 String?
  phone               String?
  timezone            String    @default("America/Sao_Paulo")
  bookingPageTitle    String?   @map("booking_page_title")
  bookingPageBanner   String?   @map("booking_page_banner")
  minimumNotice       Int       @default(60) @map("minimum_notice")
  maxDaysInAdvance    Int       @default(60) @map("max_days_in_advance")
  stripeCustomerId    String?   @unique @map("stripe_customer_id")
  stripeAccountId     String?   @unique @map("stripe_account_id")
  stripeAccountStatus String?   @map("stripe_account_status")
  plan                String    @default("free")
  planExpiresAt       DateTime? @map("plan_expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  accounts     Account[]
  sessions     Session[]
  services     Service[]
  availability Availability[]
  bookings     Booking[]
  customers    Customer[]

  @@map("users")
}

model Account {
  id                       String    @id @default(cuid())
  userId                   String    @map("user_id")
  type                     String
  provider                 String
  providerAccountId        String    @map("provider_account_id")
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  googleCalendarId         String?   @map("google_calendar_id")
  googleCalendarEnabled    Boolean   @default(false) @map("google_calendar_enabled")
  googleCalendarSyncToken  String?   @map("google_calendar_sync_token")
  googleCalendarLastSyncAt DateTime? @map("google_calendar_last_sync_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Service {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  name                  String
  description           String?
  slug                  String
  color                 String   @default("#22c55e")
  isActive              Boolean  @default(true) @map("is_active")
  isPublic              Boolean  @default(true) @map("is_public")
  durationInMinutes     Int      @map("duration_in_minutes")
  bufferTimeBefore      Int      @default(0) @map("buffer_time_before")
  bufferTimeAfter       Int      @default(0) @map("buffer_time_after")
  price                 Int      @default(0)
  currency              String   @default("BRL")
  paymentRequired       Boolean  @default(false) @map("payment_required")
  isVideoCall           Boolean  @default(false) @map("is_video_call")
  videoCallProvider     String?  @map("video_call_provider")
  customMeetingUrl      String?  @map("custom_meeting_url")
  maxAdvanceBookingDays Int?     @map("max_advance_booking_days")
  minimumNoticeMinutes  Int?     @map("minimum_notice_minutes")
  maxParticipants       Int      @default(1) @map("max_participants")
  position              Int      @default(0)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  availability Availability[]

  @@unique([userId, slug])
  @@map("services")
}

model Availability {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  serviceId String?  @map("service_id")
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([userId, serviceId, dayOfWeek])
  @@map("availability")
}

model Customer {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  name            String
  email           String
  phone           String?
  notes           String?
  tags            String[]  @default([])
  source          String?
  totalBookings   Int       @default(0) @map("total_bookings")
  totalSpentCents Int       @default(0) @map("total_spent_cents")
  lastBookingAt   DateTime? @map("last_booking_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([userId, email])
  @@index([userId, lastBookingAt])
  @@map("customers")
}

model Booking {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  serviceId             String    @map("service_id")
  customerId            String    @map("customer_id")
  startAt               DateTime  @map("start_at")
  endAt                 DateTime  @map("end_at")
  customerTimezone      String    @default("America/Sao_Paulo") @map("customer_timezone")
  status                String    @default("confirmed")
  cancelledAt           DateTime? @map("cancelled_at")
  cancelReason          String?   @map("cancel_reason")
  paymentStatus         String    @default("unpaid") @map("payment_status")
  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?   @unique @map("stripe_charge_id")
  paidAmountCents       Int       @default(0) @map("paid_amount_cents")
  paidAt                DateTime? @map("paid_at")
  refundedAmountCents   Int       @default(0) @map("refunded_amount_cents")
  refundedAt            DateTime? @map("refunded_at")
  meetingUrl            String?   @map("meeting_url")
  googleCalendarEventId String?   @map("google_calendar_event_id")
  customerNotes         String?   @map("customer_notes")
  internalNotes         String?   @map("internal_notes")
  manageToken           String    @unique @default(cuid()) @map("manage_token")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  notificationLogs NotificationLog[]

  @@index([userId, startAt])
  @@index([userId, status])
  @@index([customerId])
  @@map("bookings")
}

model NotificationLog {
  id                String    @id @default(cuid())
  bookingId         String    @map("booking_id")
  type              String
  template          String
  recipient         String
  status            String    @default("PENDING")
  providerMessageId String?   @map("provider_message_id")
  errorMessage      String?   @map("error_message")
  subject           String?
  body              String?
  scheduledFor      DateTime? @map("scheduled_for")
  sentAt            DateTime? @map("sent_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status, scheduledFor])
  @@map("notification_logs")
}